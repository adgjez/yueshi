<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="?attr/actionBarStyle"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title="@string/ai_image_generate"
        app:titleTextAppearance="@style/ToolbarTitle" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:background="@color/background_card">

        <io.legado.app.ui.widget.image.PhotoView
            android:id="@+id/photo_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tv_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="18dp"
            android:textSize="14sp"
            android:visibility="gone"
            tools:ignore="RtlHardcoded" />

    </FrameLayout>

    <EditText
        android:id="@+id/et_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="14dp"
        android:background="@color/background_card"
        android:gravity="top|start"
        android:hint="@string/ai_image_prompt_hint"
        android:inputType="textMultiLine|textCapSentences"
        android:minLines="3"
        android:maxLines="6"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        android:textColor="@color/primaryText"
        android:textColorHint="@color/secondaryText"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        tools:ignore="RtlHardcoded">

        <TextView
            android:id="@+id/btn_optimize_prompt"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:minWidth="92dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/ai_image_optimize_prompt"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_regenerate"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:minWidth="92dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/ai_image_regenerate"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_insert"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:minWidth="82dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/ai_image_insert"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
